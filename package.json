{
  "name": "sortedindex",
  "version": "0.1.1",
  "description": "A simple npm package that provides a binary search function for a sorted array",
  "main": "dist/index.js",
  "browser": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run",
    "build": "rollup -c rollup.config.mjs",
    "build:docs": "typedoc --out ./docs ./lib/index.ts",
    "watch": "rollup -cw rollup.config.mjs",
    "clean": "del-cli dist",
    "prettify": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arcatdmz/sortedIndex.git"
  },
  "keywords": [
    "sortedindex",
    "array"
  ],
  "author": "Jun Kato <i@junkato.jp> (https://junkato.jp)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/arcatdmz/sortedIndex/issues"
  },
  "homepage": "https://github.com/arcatdmz/sortedIndex#readme",
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "del-cli": "^7.0.0",
    "prettier": "^3.8.3",
    "rollup": "^4.60.3",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
